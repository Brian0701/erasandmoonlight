# ──────────────────────────────────────────
#  Eras & Moonlight — Backend Config
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ──────────────────────────────────────────

# Server
PORT=3001

# MySQL / XAMPP
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=          # leave empty if your XAMPP MySQL has no root password
DB_NAME=eras_moonlight

# JWT  — change this to any long random string in production!
JWT_SECRET=eras_moonlight_super_secret_key_2026
JWT_EXPIRES_IN=7d

# CORS — origin of your frontend (file:// or a local server)
# Separate multiple origins with a comma.
CORS_ORIGIN=*